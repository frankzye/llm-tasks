# Required for /api/chat
OPENAI_API_KEY=sk-...

# Optional: OpenAI-compatible API base URL (e.g. https://api.openai.com/v1 or your gateway)
OPENAI_BASE_URL=

# Optional: defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Optional: if set, POST /api/cron requires Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
